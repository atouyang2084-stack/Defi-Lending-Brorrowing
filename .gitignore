# ============================================
# DeFi Lending - Git Ignore Rules
# Keep repository clean and runnable after clone
# ============================================

# Dependencies
node_modules/
frontend/node_modules/

# Build outputs / generated files
artifacts/
cache/
typechain/
coverage/
frontend/dist/
frontend/.vite/
*.tsbuildinfo

# Environment / secrets
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# IDE / editor
.idea/
.vscode/

# OS files
.DS_Store
Thumbs.db

# Temporary / backup files
*.tmp
*.temp
*.bak
*.backup
*.swp

# Local AI / tool metadata
.claude/

# Project cleanup helper scripts
cleanup-for-github.*

# Optional local test pages
frontend/public/simple-test.html
frontend/public/test-repay.html
frontend/public/test.html

# Markdown upload policy: keep only root README + USAGE
**/*.md
!/README.md
!/readme.md
!/USAGE.md
!/PROJECT_REPORT.md


