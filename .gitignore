# ============================================
# DeFi Lending - Git Ignore Rules
# Keep repository clean and runnable after clone
# ============================================

# Dependencies
node_modules/
frontend/node_modules/

# Build outputs / generated files
artifacts/
cache/
typechain/
coverage/
frontend/dist/
frontend/.vite/
*.tsbuildinfo

# Environment / secrets
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# IDE / editor
.idea/
.vscode/

# OS files
.DS_Store
Thumbs.db

# Temporary / backup files
*.tmp
*.temp
*.bak
*.backup
*.swp

# Local AI / tool metadata
.claude/

# Project cleanup helper scripts
cleanup-for-github.*

# Optional local test pages
frontend/public/simple-test.html
frontend/public/test-repay.html
frontend/public/test.html

# Root-level temporary test/debug scripts
/check-*.js
/debug-*.js
/diagnose-*.js
/test-*.js
/quick-*.js
/complete-test.js
/add-liquidity.js
/calculate-liquidation.js
/direct-liquidation.js
/final-setup.js
/final-test-liquidation.js
/fix-price-script.js
/force-update-oracle.js
/fresh-setup.js
/setup-for-liquidation.js

# scripts/ temporary test/debug helpers
/scripts/analyze-*.js
/scripts/check-*.js
/scripts/debug-*.js
/scripts/diagnose-*.js
/scripts/test-*.js
/scripts/reproduce-*.js
/scripts/setup-test-account*.js
/scripts/find-min-deposit.js
/scripts/manual-approve.js
/scripts/send-eth.js
/scripts/demo-repay-with-approval.js

# Keep essential scripts for normal usage/demo
!/scripts/copy-abi.js
!/scripts/simulate-price-drop.js
!/scripts/restore-price.js
!/scripts/mint-to-any-account.js

# Markdown upload policy: keep only root README + USAGE
**/*.md
!/README.md
!/readme.md
!/USAGE.md
!/PROJECT_REPORT.md


